--- a/build.rs	2006-07-24 09:21:28
+++ b/build.rs	2026-06-26 11:36:12
@@ -65,7 +65,12 @@
 		.flag("-fno-omit-frame-pointer")
 		.flag("-fexceptions")
 		.flag("-Wall")
-		.flag("-O3")
+		// better-yoga's shipped build config: -O2 + ThinLTO (see
